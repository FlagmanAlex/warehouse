{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@warehouse/interfaces": ["../interfaces"],
      "@warehouse/config": ["../config"]
    }
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}